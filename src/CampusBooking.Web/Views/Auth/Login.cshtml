<h2>Login</h2>

<form method="post">

    <div class="mb-3">
        <label>Email</label>
        <input
            class="form-control"
            type="email"
            name="email"
            placeholder="admin@campus.local" />
    </div>

    <div class="mb-3">
        <label>Password</label>
        <input
            class="form-control"
            type="password"
            name="password"
            placeholder="Password" />
    </div>

    <button class="btn btn-primary" type="submit">
        Login
    </button>

</form>

@Html.ValidationSummary(false, "", new { @class = "text-danger" })